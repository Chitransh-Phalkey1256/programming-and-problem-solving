n = int(input("dimension: "))
A=[]
print("first matrix:")
for i in range(n):
	r = list(map(int,input().split()))
	A.append(r)

B=[]
print("second matrix:")
for i in range(n):
	r =list(map(int,input().split()))
	B.append(r)

C=[]
for i in range(n):
	C.append([0]*n)

for i in range(n):
	for j in range(n):
		for k in range(n):
			C[i][j]=C[i][j]+A[i][k]*B[k][j]

print("Resultant Matrix:")
for i in range(n):
	for j in range(n):
		if(j < n-1):
			print(C[i][j],end=" ")
		else:
			print(C[i][j],end="")
	print()
